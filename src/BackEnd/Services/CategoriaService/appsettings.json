{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "MySqlConnectionString": "Server=internal;Port=3306;Database=Dev.DespesasPessoaisDB;Uid=docker;Pwd=docker;SslMode=none;"
  },
  "ServiceSettings": {
    "ServiceName": "categoria-service",
    "ServiceHost": "categoria-service",
    "ServicePort": "9001",
    "ServiceDiscoveryAddress": "http://consul:8500"
  },
  "IdentityServerSettings": {
    "Authority": "https://internal:7199",
    "ApiName": "categoria-service",
    "ApiSecret": "sts-secret-categoria",
    "RequireHttpsMetadata": false
  },
  "Kestrel": {
    "AddServerHeader": false,
    "Endpoints": {
      "Http": {
        "Url": "http://+:9001"
      },
      "Https": {
        "Url": "https://+:7001",
        "Certificate": {
          "Path": ".cert/categoria-service_dev.pfx",
          "Password": ""
        }
      }
    }
  }
}