{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "SqlServerConnectionString": "Server=(localdb)\\MSSQLLocalDB;Database=Dev.DespesasPessoaisDB;Trusted_Connection=True;",
    "MySqlConnectionString": "Server=internal;Port=3306;Database=Dev.DespesasPessoaisDB;Uid=local;Pwd=!12345;SslMode=none;",
    "OracleConnectionString": "User Id=migrations;Password=migrations;Data Source=192.168.56.101:1521/XEPDB1;"
  },
  "ServiceSettings": {
    "ServiceName": "categoria-service",
    "ServiceHost": "internal",
    "ServicePort": "9001",
    "ServiceDiscoveryAddress": "http://internal:8500"
  },
  "IdentityServerSettings": {
    "Authority": "https://internal:7199",
    "ApiName": "api-gateway",
    "ApiSecret": "sts-secret-api-gateway",
    "RequireHttpsMetadata": false
  },
  "Kestrel": {
    "AddServerHeader": false,
    "Endpoints": {
      "Http": {
        "Url": "http://+:9001"
      },
      "Https": {
        "Url": "https://+:7001",
        "Certificate": {
          "Path": ".cert/categoria-service_dev.pfx"
        }
      }
    }
  }
}